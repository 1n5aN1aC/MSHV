QMAKE_TARGET  = MSHV_WIN64
DESTDIR        = bin\ #avoid trailing-slash linebreak
TARGET         = MSHV_WIN64.exe
DESTDIR_TARGET = bin\MSHV_WIN64.exe

####### Build rules

first: all
all: Makefile.Release  bin/MSHV_WIN64.exe

bin/MSHV_WIN64.exe: C:/Qt/5.15.2/mingw81_64/lib/libQt5AxContainer.a C:/Qt/5.15.2/mingw81_64/lib/libQt5AxBase.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Widgets.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Gui.a C:/Qt/5.15.2/mingw81_64/lib/libQt5WebSockets.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Network.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Core.a C:/Qt/5.15.2/mingw81_64/lib/libqtmain.a $(OBJECTS) build/ms_ico_win_res.o
	$(LINKER) $(LFLAGS) -o $(DESTDIR_TARGET) @object_script.MSHV_WIN64.Release  $(LIBS)

build/ms_ico_win_res.o: src/ms_ico_win.rc src/config.h
	windres -i src\ms_ico_win.rc -o build\ms_ico_win_res.o --include-dir=./src $(DEFINES)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release MSHV_WIN64.pro

qmake_all: FORCE

dist:
